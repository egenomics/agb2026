/*
 * nextflow.config — pipeline-wide defaults for the AGB2026 project.
 *
 * Architecture:
 *   nextflow.config          ← profiles + global settings (this file)
 *   conf/base.config         ← process resource labels (cpus / memory / time)
 *   conf/test.config         ← bundled test-data parameters
 *   conf/hpc_slurm.config    ← SLURM-specific overrides (copy + adapt per site)
 *
 * Override per-site by passing -c my_cluster.config on the CLI.
 */

// ── Apply base resource config to all profiles ─────────────────────────────
includeConfig 'conf/base.config'

// ── Pipeline parameters ────────────────────────────────────────────────────
params {
    outdir        = "results"
    feature_table = null
    taxonomy      = null
    metadata      = null
    alpha             = null
    distance_matrix   = null
    mode              = 'cohort'   // 'cohort' | 'patient' | 'all'
}

// ── Execution profiles ─────────────────────────────────────────────────────
profiles {

    // ── Local execution with conda (default) ─────────────────────────────
    conda {
        conda.enabled  = true
        conda.useMamba = false   // set true if mamba is available (faster solves)
    }

    // ── SLURM cluster ─────────────────────────────────────────────────────
    slurm {
        conda.enabled          = true
        process.executor       = 'slurm'
        process.clusterOptions = ''      // add '--account=<project>' for your cluster
        process.queue          = 'normal'
        process.errorStrategy  = 'retry'
        process.maxRetries     = 1
    }

    // ── SGE / Grid Engine ─────────────────────────────────────────────────
    sge {
        conda.enabled    = true
        process.executor = 'sge'
        process.penv     = 'smp'
        process.queue    = 'all.q'
    }

    // ── Singularity (for clusters that forbid conda but allow containers) ─
    // Build image first — see Dockerfile and README § Container build.
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true   // required so the staged code dir is visible
        process.container      = 'ghcr.io/egenomics/microsee-report:latest'
    }

    // ── Docker (requires ghcr.io/egenomics/microsee-report:latest — see docker-report.yml) ─
    // Prefer -profile conda until the image is available on GHCR.
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.container = 'ghcr.io/egenomics/microsee-report:latest'
    }

    // ── Apptainer (drop-in Singularity replacement on newer HPC clusters) ─
    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
        process.container    = 'ghcr.io/egenomics/microsee-report:latest'
    }

    // ── Test profile: uses bundled fixture data ───────────────────────────
    // Usage: nextflow run workflows/groupD.nf -profile test,conda
    test {
        includeConfig 'conf/test.config'
    }

}

// ── Local executor resource cap ────────────────────────────────────────────
executor {
    cpus   = Runtime.runtime.availableProcessors()
    memory = '16 GB'
}

// ── Pipeline execution reports ─────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
}
