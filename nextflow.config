/*
 * nextflow.config — pipeline-wide defaults for the AGB2026 project.
 *
 * Override per-site by creating a local nextflow.config or passing
 * -c my_cluster.config on the CLI.
 */

// ── Output directory ──────────────────────────────────────────────────────────
params {
    outdir        = "results"
    feature_table = null
    taxonomy      = null
    metadata      = null
    alpha         = null
    mode          = 'cohort'   // 'cohort' | 'patient' | 'all'
}

// ── Resource labels ───────────────────────────────────────────────────────────
// Adjust cpus / memory / time to match your cluster's queue limits.
process {
    withLabel: 'process_low' {
        cpus   = 2
        memory = '8.GB'
        time   = '1.h'
    }
    withLabel: 'process_medium' {
        cpus   = 8
        memory = '32.GB'
        time   = '4.h'
    }
    withLabel: 'process_high' {
        cpus   = 16
        memory = '64.GB'
        time   = '8.h'
    }
}

// ── Execution profiles ────────────────────────────────────────────────────────
profiles {

    // Default: local execution with conda environments
    conda {
        conda.enabled          = true
        conda.useMamba         = false   // set true if mamba is available (faster solves)
        // Do NOT set process.conda here — each process declares its own conda directive
    }

    // SLURM cluster (common on HPC)
    slurm {
        conda.enabled          = true
        process.executor       = 'slurm'
        process.clusterOptions = ''      // add '--account=<project>' or equivalent for your cluster
        process.queue          = 'normal' // change to match your cluster's partition name
    }

    // SGE / Grid Engine cluster
    sge {
        conda.enabled          = true
        process.executor       = 'sge'
        process.penv           = 'smp'
        process.queue          = 'all.q'
    }

    // Singularity (for clusters that forbid conda but allow containers)
    // Build image first: see report_generator/Dockerfile
    //   docker build -t ghcr.io/agb2026/microsee:latest report_generator/
    //   docker push ghcr.io/agb2026/microsee:latest
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true   // auto bind-mounts work dir — required for staged code
        process.container      = 'ghcr.io/agb2026/microsee:latest'
    }

    // Docker (local development / CI)
    // Build image first: docker build -t ghcr.io/agb2026/microsee:latest report_generator/
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        process.container      = 'ghcr.io/agb2026/microsee:latest'
    }

    // Test profile: uses bundled fixture files (12 patients × 2 timepoints = 24 samples, all metrics, clinical data)
    test {
        params.feature_table = "${projectDir}/modules/groupD/microsee_report/tests/data/feature-table.tsv"
        params.taxonomy      = "${projectDir}/modules/groupD/microsee_report/tests/data/taxonomy.tsv"
        params.metadata      = "${projectDir}/modules/groupD/microsee_report/tests/data/metadata.tsv"
        params.alpha         = "${projectDir}/modules/groupD/microsee_report/tests/data/alpha-diversity.tsv"
        params.outdir        = "results/test"
        process.cpus         = 1
        process.memory       = '2.GB'
        process.time         = '10.m'
    }
}

// ── Nextflow execution settings ───────────────────────────────────────────────
executor {
    $local {
        cpus   = Runtime.runtime.availableProcessors()
        memory = '16 GB'
    }
}

// ── Reporting ─────────────────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
}
