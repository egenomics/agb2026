__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/
*.egg/
*.whl

# Type-checking / lint caches
.mypy_cache/
.ruff_cache/
.pytype/

# Test caches
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── Nextflow ──────────────────────────────────────────────────────────────────
.nextflow/
.nextflow.log*
work/
results/
