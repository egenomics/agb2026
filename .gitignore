# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Editor / tooling ─────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Claude Code (AI assistant — local settings, never shared) ─────────────────
.claude/

# ── VS Code workspace file (local developer convenience — not shared) ─────────
*.code-workspace

# ── pip-compile lock files (pyproject.toml is the authoritative pin) ──────────
requirements.lock
requirements-dev.txt

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── Test / temp outputs ───────────────────────────────────────────────────────
/tmp/microsee_report*.html

# ── plotly.min.js MUST be committed — do NOT ignore it ───────────────────────
