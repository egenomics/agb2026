conda.enabled = true

params {
    sampling_depth = 1103
    outdir         = "results"
}

process {
    withName: 'diversity_analysis' {
        conda = '/data/upfagb/.conda/envs/qiime2-amplicon-2026.1'
	cpus   = 4
        memory = '8 GB'
        time   = '2 h'
        publishDir = [
            path: { "${params.outdir}/diversity_table" },
            mode: 'copy'
        ]
    }
}
