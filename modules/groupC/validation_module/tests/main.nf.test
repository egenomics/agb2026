nextflow_process {

    name "Test process VALIDATION_MODULE"
    script "../main.nf"
    process "VALIDATION_MODULE"

    test("VALIDATION_MODULE - basic") {

        when {
            params {
                outdir = "test-output"
            }
            process {
                """
                input[0] = [[ id:'test' ], file('${baseDir}/tests/fixtures/analysis.tsv')]
                input[1] = file('${baseDir}/tests/fixtures/metadata.json')
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.validated_results).match() },
                { assert snapshot(process.out.quality_metrics).match() }
            )
        }

    }

}
