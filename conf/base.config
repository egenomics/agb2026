/*
 * conf/base.config — process resource defaults for all profiles.
 *
 * Override any value in a site-specific config or by passing -c my_site.config.
 * Labels are declared in each process with `label 'process_low'` etc.
 */

process {

    // Fail fast and do not retry by default (useful for interactive runs).
    // Set errorStrategy = 'retry' and maxRetries = 2 on HPC where job failures
    // are more common (node preemption, OOM, scheduler timeouts).
    errorStrategy = 'terminate'
    maxRetries    = 0

    // ── Label-based resource allocation ──────────────────────────────────────
    // Adjust these to match your cluster's queue limits.

    withLabel: 'process_low' {
        cpus   = { 2  * task.attempt }
        memory = { 8.GB  * task.attempt }
        time   = { 1.h   * task.attempt }
    }

    withLabel: 'process_medium' {
        cpus   = { 8  * task.attempt }
        memory = { 32.GB * task.attempt }
        time   = { 4.h   * task.attempt }
    }

    withLabel: 'process_high' {
        cpus   = { 16 * task.attempt }
        memory = { 64.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
}
