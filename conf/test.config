/*
 * conf/test.config — minimal test profile parameters.
 *
 * Uses the fixture TSV files bundled with the report generator.
 * Run with:   nextflow run workflows/groupD.nf -profile test,conda
 */

params {
    feature_table = "${projectDir}/../modules/groupD/microsee_report/tests/data/feature-table.tsv"
    taxonomy      = "${projectDir}/../modules/groupD/microsee_report/tests/data/taxonomy.tsv"
    metadata      = "${projectDir}/../modules/groupD/microsee_report/tests/data/metadata.tsv"
    alpha         = "${projectDir}/../modules/groupD/microsee_report/tests/data/alpha-diversity.tsv"
    mode          = "all"
    outdir        = "results/test"
}

process {
    // Tight resource caps for CI / local test runs
    cpus   = 1
    memory = '2.GB'
    time   = '10.m'
}
