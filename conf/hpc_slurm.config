/*
 * conf/hpc_slurm.config — SLURM cluster overrides.
 *
 * Copy this file and adjust for your cluster.  Load it alongside a base
 * profile with:   nextflow run workflows/groupD.nf -profile conda -c conf/hpc_slurm.config
 *
 * Common changes needed:
 *   - process.queue          → your partition name (e.g. 'standard', 'short')
 *   - process.clusterOptions → add --account=<project> if required
 *   - executor.$slurm.queueSize → maximum concurrent jobs your allocation allows
 */

process {
    executor       = 'slurm'
    queue          = 'normal'       // change to match your cluster's partition name
    clusterOptions = ''             // e.g. '--account=myproject --qos=normal'

    // Automatically retry once on node failures (common on busy HPC clusters)
    errorStrategy  = 'retry'
    maxRetries     = 1

    // MICROSEE_REPORT (label process_low): cohort mode ≈ 2–4 GB RAM;
    // --mode all on large studies may need 8–16 GB — override here if OOM:
    // withName: 'MICROSEE_REPORT' {
    //     memory = '16.GB'
    //     time   = '2.h'
    // }
}

executor {
    $slurm {
        queueSize = 50              // maximum jobs submitted at once; raise if allowed
        submitRateLimit = '10/1min' // protect scheduler from burst submissions
    }
}
